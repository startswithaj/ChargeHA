# ChargeHA Environment Variables
# All other configuration (Tesla, Fronius, etc.) is managed via the Settings UI or Setup Wizard.

PORT=8000
DB_PATH=./data/chargeha.db

# Log verbosity: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Required for encrypting secrets stored in the database (Tesla credentials, Fronius passwords, etc.)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
