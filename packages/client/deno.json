{
  "name": "@chargeha/client",
  "version": "0.0.1",
  "exports": "./src/main.tsx",
  "imports": {
    "react": "npm:react@^18",
    "react-dom": "npm:react-dom@^18",
    "react-dom/client": "npm:react-dom@^18/client",
    "react/jsx-runtime": "npm:react@^18/jsx-runtime",
    "@types/react": "npm:@types/react@^18",
    "@radix-ui/themes": "npm:@radix-ui/themes@^3",
    "@radix-ui/react-icons": "npm:@radix-ui/react-icons@^1",
    "lucide-react": "npm:lucide-react@^0.460",
    "vitest": "npm:vitest@^3",
    "@testing-library/react": "npm:@testing-library/react@^16",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@^6",
    "@testing-library/user-event": "npm:@testing-library/user-event@^14",
    "jsdom": "npm:jsdom@^25",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@^3",
    "vite": "npm:vite@^6",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1",
    "@tanstack/react-query": "npm:@tanstack/react-query@^5",
    "@tanstack/react-query-devtools": "npm:@tanstack/react-query-devtools@^5",
    "qrcode.react": "npm:qrcode.react@^4",
    "recharts": "npm:recharts@^2",
    "vitest/config": "npm:vitest@^3/config",
    "@trpc/client": "npm:@trpc/client@^11",
    "@trpc/react-query": "npm:@trpc/react-query@^11",
    "@trpc/server": "npm:@trpc/server@^11",
    "chart.js": "npm:chart.js@^4"
  },
  "tasks": {
    "dev": "deno run -A --unstable-no-legacy-abort npm:vite@^6 dev",
    "build": "deno run -A npm:vite@^6 build",
    "build:demo": "VITE_DEMO_MODE=1 deno run -A npm:vite@^6 build --base=/ChargeHA/",
    "test": "deno run -A npm:vitest@^3 run",
    "test:watch": "deno run -A npm:vitest@^3",
    "test:coverage": "deno run -A npm:vitest@^3 run --coverage"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["@testing-library/jest-dom/vitest"]
  }
}
